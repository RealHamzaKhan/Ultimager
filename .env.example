# ─────────────────────────────────────────────────────────────────────────────
# GradeForge — Environment Configuration
#
# Copy this file to .env and fill in your values.
# All LLM settings use LLM_* names so any OpenAI-compatible provider works.
# The old NVIDIA_* names are still accepted as aliases (backward compat).
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Any OpenAI-compatible API works here. Examples:
#
#   NVIDIA NIM (default):
#     LLM_BASE_URL=https://integrate.api.nvidia.com/v1
#     LLM_MODEL=meta/llama-4-maverick-17b-128e-instruct
#
#   OpenAI:
#     LLM_BASE_URL=https://api.openai.com/v1
#     LLM_MODEL=gpt-4o
#
#   Together AI:
#     LLM_BASE_URL=https://api.together.xyz/v1
#     LLM_MODEL=meta-llama/Llama-3-70b-chat-hf
#
#   Groq:
#     LLM_BASE_URL=https://api.groq.com/openai/v1
#     LLM_MODEL=llama3-70b-8192
#
#   Ollama (local, no API key needed):
#     LLM_BASE_URL=http://localhost:11434/v1
#     LLM_MODEL=llama3
#     LLM_API_KEY=ollama

LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_MODEL=meta/llama-4-maverick-17b-128e-instruct

# Optional: use a different model for rubric generation (defaults to LLM_MODEL)
# LLM_RUBRIC_MODEL=meta/llama-4-maverick-17b-128e-instruct

# ── Request settings ──────────────────────────────────────────────────────────
# HTTP timeout per API call in seconds (increase for slow providers / large models)
LLM_TIMEOUT=120.0

# Requests per minute — lower this if your provider has a stricter rate limit
# NVIDIA NIM free tier: 40 RPM  |  OpenAI tier-1: 500 RPM  |  Groq free: 30 RPM
RATE_LIMIT_RPM=40

# ── Max tokens per call type ──────────────────────────────────────────────────
MAX_TOKENS_JUDGE=800
MAX_TOKENS_GRADING=4000
MAX_TOKENS_RETRY=2000
MAX_TOKENS_ROUTING=2000
MAX_TOKENS_CHECKPOINT_GEN=4000
MAX_TOKENS_RUBRIC=5000
MAX_TOKENS_RELEVANCE=500
MAX_TOKENS_VISION=1200

# ── Judge context window ──────────────────────────────────────────────────────
# Max chars of student content sent to the judge per checkpoint.
# 60000 covers even large Jupyter notebooks with full cell outputs.
JUDGE_CONTENT_LIMIT=60000

# ── Model context window (for multi-pass grading) ────────────────────────────
# Set to match your model's context window.
# Llama 4 Maverick = 128000 tokens  |  GPT-4o = 128000  |  Groq Llama3-70b = 8192
MODEL_CONTEXT_TOKENS=128000
MODEL_RESERVED_TOKENS=12000
CHARS_PER_TOKEN_ESTIMATE=3.2

# ── Vision settings ───────────────────────────────────────────────────────────
ENABLE_VISION_PREANALYSIS=1
NVIDIA_MAX_IMAGES_PER_REQUEST=8
MAX_IMAGES_PER_FILE_FOR_ROUTING=2
MAX_IMAGES_SELECTION_POOL=220
MAX_IMAGES_FOR_PREANALYSIS=200
VISION_PREANALYSIS_CHUNK_SIZE=6
MAX_IMAGES_FOR_FINAL_GRADE=8
MAX_FINAL_IMAGE_BYTES=8000000

# ── Parallel grading ──────────────────────────────────────────────────────────
PARALLEL_GRADING_ENABLED=1
# Number of students graded concurrently — lower if hitting rate limits
PARALLEL_GRADING_WORKERS=8

# ── ACMAG (Anchor-Calibrated Multi-Agent Grading) ────────────────────────────
ACMAG_ENABLED=0
ACMAG_CALIBRATION_RATIO=0.10
ACMAG_MIN_CALIBRATION=3
ACMAG_MAX_CALIBRATION=12
ACMAG_BLIND_REVIEW_RATIO=0.30
ACMAG_KAPPA_THRESHOLD=0.60
ACMAG_MODERATION_SCORE_DELTA=1.0
ACMAG_MAX_ANCHORS=8
