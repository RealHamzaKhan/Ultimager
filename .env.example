# ─────────────────────────────────────────────────────────────────────────────
# GradeForge — Environment Configuration
#
# Copy this file to .env and fill in your values.
# Supports any OpenAI-compatible API provider.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Switch providers by changing these three lines. Examples:
#
#   NVIDIA NIM (default — free tier available at build.nvidia.com):
#     LLM_BASE_URL=https://integrate.api.nvidia.com/v1
#     LLM_MODEL=meta/llama-4-maverick-17b-128e-instruct
#
#   OpenAI:
#     LLM_BASE_URL=https://api.openai.com/v1
#     LLM_MODEL=gpt-4o
#
#   Groq (fast, free tier):
#     LLM_BASE_URL=https://api.groq.com/openai/v1
#     LLM_MODEL=llama3-70b-8192
#     RATE_LIMIT_RPM=30
#     MODEL_CONTEXT_TOKENS=8192
#
#   Together AI:
#     LLM_BASE_URL=https://api.together.xyz/v1
#     LLM_MODEL=meta-llama/Llama-3-70b-chat-hf
#
#   Ollama (local, no API key needed):
#     LLM_BASE_URL=http://localhost:11434/v1
#     LLM_API_KEY=ollama
#     LLM_MODEL=llama3

LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_MODEL=meta/llama-4-maverick-17b-128e-instruct

# Optional: use a separate (cheaper/faster) model for rubric generation.
# Defaults to LLM_MODEL when not set.
# LLM_RUBRIC_MODEL=meta/llama-4-maverick-17b-128e-instruct

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Set to your provider's RPM limit to avoid 429 errors.
# NVIDIA NIM free: 40  |  OpenAI tier-1: 500  |  Groq free: 30
RATE_LIMIT_RPM=40

# Number of students graded in parallel — lower if hitting rate limits.
PARALLEL_GRADING_WORKERS=8

# ── Request timeout ───────────────────────────────────────────────────────────
# Seconds to wait for a single API call. Increase for slow providers.
LLM_TIMEOUT=120.0

# ── Model context window ──────────────────────────────────────────────────────
# Set to match your model's token limit. Controls multi-pass grading threshold.
# Llama 4 Maverick / GPT-4o = 128000  |  Groq Llama3-70b = 8192
MODEL_CONTEXT_TOKENS=128000

# ── Judge context limit ───────────────────────────────────────────────────────
# Max characters of student content sent to the judge per grading call.
# 60000 covers large Jupyter notebooks. Reduce to cut token costs.
JUDGE_CONTENT_LIMIT=60000

# ── Vision analysis ───────────────────────────────────────────────────────────
ENABLE_VISION_PREANALYSIS=1
NVIDIA_MAX_IMAGES_PER_REQUEST=8

# ── ACMAG (Anchor-Calibrated Multi-Agent Grading) ────────────────────────────
# Advanced calibration feature — leave off unless you need it.
ACMAG_ENABLED=0
