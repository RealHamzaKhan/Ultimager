# NVIDIA NIM API - Primary and Only Provider
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_MODEL=qwen/qwen3.5-397b-a17b
NVIDIA_MAX_IMAGES_PER_REQUEST=14

# Provider Configuration - Single provider only
LLM_PROVIDER_ORDER=nvidia
SCORING_PRIMARY_PROVIDER=nvidia
SCORING_ALLOW_FALLBACK=0
SCORING_CONSISTENCY_ALERT_DELTA=1.5

# Vision Analysis Configuration
ENABLE_VISION_PREANALYSIS=1
MAX_IMAGES_SELECTION_POOL=220
MAX_IMAGES_FOR_PREANALYSIS=200
VISION_PREANALYSIS_CHUNK_SIZE=6
MAX_IMAGES_FOR_FINAL_GRADE=14
MAX_FINAL_IMAGE_BYTES=8000000

# ACMAG Configuration (Anchor-Calibrated Multi-Agent Grading)
ACMAG_ENABLED=1
ACMAG_CALIBRATION_RATIO=0.10
ACMAG_MIN_CALIBRATION=3
ACMAG_MAX_CALIBRATION=12
ACMAG_BLIND_REVIEW_RATIO=0.30
ACMAG_KAPPA_THRESHOLD=0.60
ACMAG_MODERATION_SCORE_DELTA=1.0
ACMAG_MAX_ANCHORS=8
